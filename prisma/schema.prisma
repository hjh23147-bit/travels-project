generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // SUPER_ADMIN or AGENCY_ADMIN
  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model Agency {
  id           String    @id @default(uuid())
  name         String
  description  String?
  logo         String?
  coverImage   String?
  contactPhone String?
  whatsapp     String?
  instagram    String?
  x_link       String?
  subscriptionType   String    @default("NONE") // MONTHLY, YEARLY, NONE
  subscriptionEndsAt DateTime?
  isActive           Boolean   @default(true)
  users              User[]
  packages     Package[]
  services     Service[]
  leads        Lead[]
  ads          Advertisement[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive])
  @@index([isActive, subscriptionEndsAt])
  @@index([createdAt])
}

model Lead {
  id             String   @id @default(uuid())
  name           String
  phone          String
  country        String
  serviceType    String
  travelersCount Int
  travelDate     DateTime
  budget         Float
  status         String   @default("NEW")
  notes          String?
  packageId      String?
  package        Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  agencyId       String?
  agency         Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([agencyId])
  @@index([createdAt])
}

model Package {
  id           String   @id @default(uuid())
  title        String
  description  String
  price        Float
  discount     Float    @default(0)
  features     String
  type         String
  isActive     Boolean  @default(true)
  imageUrl     String?
  duration     String?
  hotelMakkah  String?
  hotelMadinah String?
  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  leads        Lead[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([agencyId, isActive])
  @@index([type, isActive])
  @@index([price])
}

model Service {
  id           String   @id @default(uuid())
  title        String
  description  String
  price        Float?
  isActive     Boolean  @default(true)
  requirements String?
  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([agencyId])
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id        String   @id @default(uuid())
  name      String?
  phone     String?
  message   String
  response  String?
  isLead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isLead])
  @@index([createdAt])
}

model Advertisement {
  id        String   @id @default(uuid())
  title     String
  content   String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId, isActive])
}
